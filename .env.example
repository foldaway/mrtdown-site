VITE_ROOT_URL=http://localhost:3000
VITE_CROWD_REPORT_TURNSTILE_SITE_KEY=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

SENTRY_DSN=
TIER=
GIT_SHA=

# Optional locally. Required before enabling Cloudflare caching in a deployed
# environment; the token needs only Cache Purge permission for this zone.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_CACHE_PURGE_TOKEN=

REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mrtdown-db

# Crowd report canonical ingest dispatch. Set the token as a secret in
# deployed environments; it needs repository dispatch permission on mrtdown-data.
CROWD_REPORT_DISPATCH_GITHUB_TOKEN=
CROWD_REPORT_DISPATCH_GITHUB_OWNER=foldaway
CROWD_REPORT_DISPATCH_GITHUB_REPO=mrtdown-data
CROWD_REPORT_DISPATCH_GITHUB_EVENT_TYPE=ingest
CROWD_REPORT_DISPATCH_LIMIT=10

MRTDOWN_DATA_URL=https://data.mrtdown.org/mrtdown-data

# Bearer token auth for internal APIs
INTERNAL_API_TOKENS=secret

# Required outside local QSTASH_DEV mode
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Local development only
QSTASH_DEV=true
QSTASH_URL=http://localhost:8080
